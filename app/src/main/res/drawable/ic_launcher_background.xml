<?xml version="1.0" encoding="utf-8"?>
<!-- ic_launcher_background.xml - Premium Obsidian Gold Theme Launcher Background -->
<!-- Defines a dark, high-end vector canvas background for the application's launcher icon -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Base background path spanning the entire 108x108 viewport -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <!-- Apply a premium linear gradient transitioning from dark navy-grey to deep solid black -->
            <gradient
                android:endX="108"
                android:endY="108"
                android:startX="0"
                android:startY="0"
                android:type="linear">
                <!-- Starting gradient stop: sleek obsidian grey-blue -->
                <item android:color="#0B0F19" android:offset="0.0" />
                <!-- Ending gradient stop: deep cosmic solid black -->
                <item android:color="#030712" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Soft golden radial light flare in the center to highlight the foreground emblem -->
    <path
        android:pathData="M54,54m-40,0a40,40 0,1 1,80 0a40,40 0,1 1,-80 0">
        <aapt:attr name="android:fillColor">
            <!-- Radial gradient centered perfectly at (54, 54) with a radius of 40 -->
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="40"
                android:type="radial">
                <!-- High luminosity golden glow at the center -->
                <item android:color="#33FBBF24" android:offset="0.0" />
                <!-- Seamless fade-out to completely transparent at the outer boundaries -->
                <item android:color="#00FBBF24" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
